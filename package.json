{
  "name": "project-pilot",
  "version": "0.1.0",
  "description": "Local-only MCP project manager connector for Trade Journal Lite.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "local": "tsx src/local-launcher.ts start",
    "local:status": "tsx src/local-launcher.ts status",
    "local:open": "tsx src/local-launcher.ts open",
    "local:stop": "tsx src/local-launcher.ts stop",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.142.1",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "openai": "^6.45.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
