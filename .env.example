HOST=127.0.0.1
PORT=3000
PROJECT_PILOT_ROOT=C:\Users\TradeStation\Projects\ai-pilot\project-pilot

# Manager Mode uses OPENAI_API_KEY only inside the local Project Pilot server.
# Do not commit .env and do not use CONTROL_PLANE_API_KEY for this.
OPENAI_API_KEY=
PROJECT_PILOT_MANAGER_MODEL=gpt-5
PROJECT_PILOT_MANAGER_MAX_DECISIONS_PER_RUN=12
PROJECT_PILOT_MANAGER_MAX_TASKS_PER_RUN=8
PROJECT_PILOT_MANAGER_MAX_FIX_ATTEMPTS_PER_TASK=1
PROJECT_PILOT_MANAGER_MAX_RUNTIME_MS=3600000

# One-terminal local launcher.
# Set PROJECT_PILOT_TUNNEL_COMMAND to the full tunnel-client executable path if it is not on PATH.
PROJECT_PILOT_TUNNEL_COMMAND=tunnel-client
PROJECT_PILOT_TUNNEL_PROFILE=project-pilot
PROJECT_PILOT_TUNNEL_ARGS=run --profile {profile}
PROJECT_PILOT_LOCAL_HEALTH_TIMEOUT_MS=30000
